---
// src/components/DemoArticleBottom.astro
import type { CollectionEntry } from "astro:content";

type Props = {
  project: CollectionEntry<"projects">;
};

// Get the requested project
const { project } = Astro.props;
const { data } = project;
const { demoType, rawImage, resultImage, videoUrl, tools = [], processSteps = [], features = [] } = data;
const { Content } = await project.render();

// Get the next and prev projects
const { getCollection } = await import("astro:content");
const projects = await getCollection("projects");
const index = projects.findIndex((x) => x.slug === project.slug);
const prev = projects[(index - 1 + projects.length) % projects.length];
const next = projects[(index + 1) % projects.length];
---

<div>
  <!-- Main Content Section -->
  <article class="space-y-8">
    <!-- Original Project Content -->
    <section class="prose dark:prose-invert max-w-none">
      <Content />
    </section>

    <!-- Demo Visuals Section -->
    <section>
      <h2 class="text-2xl font-semibold text-black dark:text-white mb-6">Project Visuals</h2>

      <!-- Video Demo -->
      {
        videoUrl && (
          <div class="mb-8">
            <h3 class="text-lg font-medium text-black dark:text-white mb-3">Video Demonstration</h3>
            <div class="aspect-video rounded-lg overflow-hidden bg-black/5 dark:bg-white/10">
              <iframe
                src={videoUrl}
                class="w-full h-full border-0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              />
            </div>
          </div>
        )
      }

      <!-- Image Comparison for Dashboard Projects -->
      {
        demoType === "dashboard" && (rawImage || resultImage) && (
          <div class="mb-8">
            <h3 class="text-lg font-medium text-black dark:text-white mb-3">Data Transformation Process</h3>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              {rawImage && (
                <div class="flex flex-col">
                  <div class="border rounded-lg overflow-hidden border-black/15 dark:border-white/20 bg-gray-50 dark:bg-gray-900 p-4 flex items-center justify-center min-h-[320px] h-full">
                    <img
                      src={rawImage}
                      alt="Raw Dataset"
                      class="w-full h-auto max-h-[280px] object-contain"
                      loading="lazy"
                    />
                  </div>
                  <p class="text-sm text-center opacity-75 mt-2">Raw Data</p>
                </div>
              )}

              {resultImage && (
                <div class="flex flex-col">
                  <div class="border rounded-lg overflow-hidden border-black/15 dark:border-white/20 bg-gray-50 dark:bg-gray-900 p-4 flex items-center justify-center min-h-[320px] h-full">
                    <img
                      src={resultImage}
                      alt="Dashboard Result"
                      class="w-full h-auto max-h-[280px] object-contain"
                      loading="lazy"
                    />
                  </div>
                  <p class="text-sm text-center opacity-75 mt-2">Final Dashboard</p>
                </div>
              )}
            </div>
          </div>
        )
      }

      <!-- Single Image for Website/Program Projects -->
      {
        (demoType === "website" || demoType === "program") && resultImage && (
          <div class="mb-8">
            <h3 class="text-lg font-medium text-black dark:text-white mb-3">Project Screenshot</h3>
            <div class="border rounded-lg overflow-hidden border-black/15 dark:border-white/20 bg-gray-50 dark:bg-gray-900 p-6 flex items-center justify-center min-h-[400px]">
              <img
                src={resultImage}
                alt="Project Screenshot"
                class="w-full h-auto max-h-[350px] object-contain"
                loading="lazy"
              />
            </div>
            <p class="text-sm mt-2 opacity-75 text-center">
              {demoType === "website" ? "Website Interface" : "Program Interface"}
            </p>
          </div>
        )
      }
    </section>

    <!-- Tools & Technologies -->
    {
      tools.length > 0 && (
        <section>
          <h2 class="text-2xl font-semibold text-black dark:text-white mb-4">Tools & Technologies</h2>
          <div class="flex flex-wrap gap-2">
            {tools.map((tool, index) => (
              <span class="px-3 py-1.5 rounded text-sm border border-black/15 dark:border-white/20 bg-black/5 dark:bg-white/10 hover:bg-black/10 hover:dark:bg-white/20 transition-colors">
                {tool}
              </span>
            ))}
          </div>
        </section>
      )
    }

    <!-- Development Process -->
    {
      processSteps.length > 0 && (
        <section>
          <h2 class="text-2xl font-semibold text-black dark:text-white mb-4">Development Process</h2>
          <div class="space-y-4">
            {processSteps.map((step, index) => (
              <div class="flex gap-3 group">
                <div class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center text-xs font-semibold group-hover:bg-blue-200 dark:group-hover:bg-blue-800 transition-colors">
                  {index + 1}
                </div>
                <div class="pt-0.5 group-hover:text-black/90 dark:group-hover:text-white/90 transition-colors">
                  {step}
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Key Features -->
    {
      features.length > 0 && (
        <section>
          <h2 class="text-2xl font-semibold text-black dark:text-white mb-4">Key Features</h2>
          <ul class="space-y-3">
            {features.map((feature, index) => (
              <li class="flex items-start gap-3 group">
                <svg
                  class="size-5 text-green-600 dark:text-green-400 mt-0.5 flex-shrink-0 group-hover:scale-110 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="group-hover:text-black/90 dark:group-hover:text-white/90 transition-colors">
                  {feature}
                </span>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>

  <!-- Navigation -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-12 pt-8 border-t border-black/10 dark:border-white/10">
    <a
      href={`/projects/${prev.slug}`}
      class="group p-4 gap-3 flex items-center border rounded-lg hover:bg-black/5 hover:dark:bg-white/10 border-black/15 dark:border-white/20 blend transition-all duration-300"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="order-1 stroke-current group-hover:stroke-black group-hover:dark:stroke-white rotate-180"
      >
        <line
          x1="5"
          y1="12"
          x2="19"
          y2="12"
          class="scale-x-0 group-hover:scale-x-100 translate-x-4 group-hover:translate-x-1 transition-all duration-300 ease-in-out"
        ></line>
        <polyline
          points="12 5 19 12 12 19"
          class="translate-x-0 group-hover:translate-x-1 transition-all duration-300 ease-in-out"></polyline>
      </svg>
      <div class="order-2 w-full h-full group-hover:text-black group-hover:dark:text-white blend">
        <div class="flex flex-wrap gap-2">
          <div class="text-sm uppercase">Previous Project</div>
        </div>
        <div class="font-semibold mt-1 text-black dark:text-white line-clamp-1">
          {prev.data.title}
        </div>
      </div>
    </a>

    <a
      href={`/projects/${next.slug}`}
      class="group p-4 gap-3 flex items-center border rounded-lg hover:bg-black/5 hover:dark:bg-white/10 border-black/15 dark:border-white/20 transition-all duration-300"
    >
      <div class="w-full h-full text-right group-hover:text-black group-hover:dark:text-white blend">
        <div class="text-sm uppercase">Next Project</div>
        <div class="font-semibold mt-1 text-black dark:text-white line-clamp-1">
          {next.data.title}
        </div>
      </div>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="stroke-current group-hover:stroke-black group-hover:dark:stroke-white"
      >
        <line
          x1="5"
          y1="12"
          x2="19"
          y2="12"
          class="scale-x-0 group-hover:scale-x-100 translate-x-4 group-hover:translate-x-1 transition-all duration-300 ease-in-out"
        ></line>
        <polyline
          points="12 5 19 12 12 19"
          class="translate-x-0 group-hover:translate-x-1 transition-all duration-300 ease-in-out"></polyline>
      </svg>
    </a>
  </div>
</div>

<style>
  /* Prose styling untuk konsistensi dengan halaman lain */
  .prose {
    color: inherit;
    max-width: none;
  }

  .prose > :first-child {
    margin-top: 0;
  }

  .prose > :last-child {
    margin-bottom: 0;
  }

  .prose p {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    line-height: 1.75;
    color: inherit;
  }

  .prose ul {
    list-style-type: disc;
    padding-left: 1.625em;
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }

  .prose ol {
    list-style-type: decimal;
    padding-left: 1.625em;
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }

  .prose li {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
    color: inherit;
  }

  .prose h2 {
    font-size: 1.5em;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 1em;
    color: inherit;
    line-height: 1.375;
  }

  .prose h3 {
    font-size: 1.25em;
    font-weight: 600;
    margin-top: 1.5em;
    margin-bottom: 0.75em;
    color: inherit;
    line-height: 1.375;
  }

  .prose a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    text-decoration-color: rgba(0, 0, 0, 0.3);
  }

  .dark .prose a {
    text-decoration-color: rgba(255, 255, 255, 0.3);
  }

  .prose a:hover {
    text-decoration-color: currentColor;
  }

  /* Image hover effects */
  img {
    transition: all 0.3s ease;
  }

  .border:hover img {
    transform: scale(1.02);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .prose h2 {
      font-size: 1.375em;
    }

    .prose h3 {
      font-size: 1.125em;
    }

    .space-y-8 > * + * {
      margin-top: 1.5rem;
    }

    /* Adjust image heights for mobile */
    .min-h-\[320px\] {
      min-height: 280px !important;
    }

    .min-h-\[400px\] {
      min-height: 320px !important;
    }

    .max-h-\[280px\] {
      max-height: 240px !important;
    }

    .max-h-\[350px\] {
      max-height: 280px !important;
    }
  }

  /* Line clamp for long titles */
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
