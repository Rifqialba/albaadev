---
// src/pages/projects/demo/private/[...slug].astro
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import { PROJECTS } from "@consts";

// Generate static paths for all projects
export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

// Get the requested project
const { project } = Astro.props;
const { data } = project;
const { title, summary, demoType } = data;

// Helper untuk mendapatkan label tipe project
const getTypeLabel = (type: string) => {
  switch (type) {
    case "dashboard":
      return "Dashboard";
    case "website":
      return "Website";
    case "ml":
      return "Machine Learning";
    case "program":
      return "Program";
    default:
      return "Project";
  }
};

const pageTitle = `${title} - Private Demo`;
---

<PageLayout title={pageTitle} description={`${title} - Private Demo Access`}>
  <TopLayout>
    <div class="animate">
      <div>
        <a
          href={`/projects/${project.slug}`}
          class="group w-fit p-1.5 gap-1.5 text-sm flex items-center border rounded hover:bg-black/5 hover:dark:bg-white/10 border-black/15 dark:border-white/20 transition-colors duration-300 ease-in-out"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="stroke-current group-hover:stroke-black group-hover:dark:stroke-white"
          >
            <line
              x1="19"
              y1="12"
              x2="5"
              y2="12"
              class="scale-x-0 group-hover:scale-x-100 translate-x-3 group-hover:translate-x-0 transition-all duration-300 ease-in-out"
            ></line>
            <polyline
              points="12 19 5 12 12 5"
              class="translate-x-1 group-hover:translate-x-0 transition-all duration-300 ease-in-out"></polyline>
          </svg>
          <div class="w-full group-hover:text-black group-hover:dark:text-white transition-colors duration-300 ease-in-out">
            Back to Project Details
          </div>
        </a>

        <div class="flex flex-wrap text-sm uppercase mt-12 gap-3 opacity-75">
          <div class="flex items-center gap-2">
            <svg class="size-5 stroke-current">
              <use href="/ui.svg#calendar"></use>
            </svg>
            Private Demo
          </div>
          <div class="flex items-center gap-2">
            <svg class="size-5 fill-current">
              <use href="/ui.svg#lock"></use>
            </svg>
            Restricted Access
          </div>
        </div>

        <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
          {title} - Demo
        </h1>

        <div class="mt-1">
          {summary}
        </div>
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <div class="flex flex-col items-center justify-center py-16 px-4 text-center">
        <!-- Lock Icon -->
        <div class="mb-6">
          <svg class="size-24 text-yellow-500 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 15v2m-6-4h12a2 2 0 012 2v6a2 2 0 01-2 2H6a2 2 0 01-2-2v-6a2 2 0 012-2zm10-4V8a4 4 0 00-8 0v3h8z"
            />
          </svg>
        </div>

        <h2 class="text-2xl font-semibold text-black dark:text-white mb-2">
          Private Demo Access
        </h2>
        
        <p class="text-lg text-black/70 dark:text-white/70 max-w-md mb-6">
          The live demo for this {getTypeLabel(demoType || "")} is currently private.
        </p>

        <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4 max-w-md mb-8">
          <p class="text-sm text-yellow-800 dark:text-yellow-200">
            <strong>Note:</strong> This project is not publicly accessible. If you'd like to request access or see a demonstration, please feel free to reach out.
          </p>
        </div>

        <div class="flex gap-3">
          <a
            href={`/projects/${project.slug}`}
            class="px-4 py-2 rounded-lg border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 transition-colors"
          >
            Back to Project Details
          </a>
          
          <a
            href="/projects"
            class="px-4 py-2 rounded-lg bg-black dark:bg-white text-white dark:text-black hover:bg-black/80 dark:hover:bg-white/80 transition-colors"
          >
            View All Projects
          </a>
        </div>

        <!-- Optional: Contact Section -->
        <div class="mt-12 pt-8 border-t border-black/10 dark:border-white/10 max-w-md">
          <p class="text-sm text-black/60 dark:text-white/60">
            Interested in this project? Feel free to 
            <a href="/contact" class="text-blue-600 dark:text-blue-400 hover:underline"> contact me </a>
            for a private demonstration.
          </p>
        </div>
      </div>
    </div>
  </BottomLayout>
</PageLayout>