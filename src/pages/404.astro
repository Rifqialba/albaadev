---
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout title="Page Not Found" description="The page you are looking for does not exist.">
  <div class="text-center py-20">
    <h1 class="text-4xl font-bold mb-4">404</h1>
    <p class="text-lg mb-6">Oops! Page not found.</p>
    <a href="/" class="px-4 py-2 bg-black text-white rounded hover:bg-gray-800">Go Home</a>
  </div>
</PageLayout>